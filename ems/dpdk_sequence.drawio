    <!-- ── Latency callout ── -->
    <mxCell id="lat_box" value="Kernel-bypass latency budget&#xa;─────────────────────────&#xa;Wire → mbuf alloc:    ~100 ns&#xa;DMA fill:             ~200 ns&#xa;ring enqueue/dequeue: ~  20 ns&#xa;parse (Eth+IP+UDP):   ~  50 ns&#xa;FIX tag scan:         ~ 100 ns&#xa;mbuf free:            ~  10 ns&#xa;─────────────────────────&#xa;Total end-to-end:     ~500 ns–2 µs&#xa;&#xa;vs kernel stack:      10–100 µs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontFamily=Courier New;fontSize=10;align=left;" vertex="1" parent="1">
      <mxGeometry x="1370" y="280" width="260" height="220" as="geometry" />
    </mxCell>

    <!-- ── Key concepts box ── -->
    <mxCell id="key_box" value="Key DPDK Concepts&#xa;─────────────────────────&#xa;rte_mempool  → MbufPool (hugepages)&#xa;rte_mbuf     → Mbuf (pkt descriptor)&#xa;rte_ring     → RX/TX ring (lock-free)&#xa;PMD          → poll loop (no interrupt)&#xa;rx_burst     → drain ring, 32 pkts/call&#xa;BPF filter   → NIC-level whitelist&#xa;RSS          → multi-queue NIC hashing&#xa;NUMA-aware   → pool on same socket as NIC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Courier New;fontSize=10;align=left;" vertex="1" parent="1">
      <mxGeometry x="1370" y="530" width="260" height="200" as="geometry" />
    </mxCell>

    <!-- ── AWS mapping box ── -->
    <mxCell id="aws_box" value="AWS Mapping&#xa;─────────────────────────&#xa;NIC (ENA/EFA)    → c5n / hpc6a NIC&#xa;hugepages        → EC2 large pages&#xa;kernel bypass    → EFA user-space driver&#xa;PMD poll core    → dedicated vCPU&#xa;RDMA Write       → rdma_transport.py&#xa;BPF filter       → Security Group equivalent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Courier New;fontSize=10;align=left;" vertex="1" parent="1">
      <mxGeometry x="1370" y="760" width="260" height="175" as="geometry" />
