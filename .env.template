# Low-Latency Trading Pipeline — Environment Template
# =====================================================
# Copy to .env and fill in your values:
#   cp .env.template .env
#
# Source before running any script:
#   source .env
#
# .env is git-ignored (machine-specific IPs).
# .env.template is committed as the canonical reference.

# ── Network ────────────────────────────────────────────────────────────────
MAC_A_IP=<Mac-A-en0-IP>         # sender machine   e.g. 192.168.1.100
MAC_B_IP=<Mac-B-en0-IP>         # EMS / capture    e.g. 192.168.1.165

# ── Ports ──────────────────────────────────────────────────────────────────
FIX_PORT=4567                   # FIX-over-UDP  (dpdk_pcap BPF filter)
MKTDATA_PORT=5678               # Protobuf market-data feed

# ── EMS destination (used by all client scripts) ───────────────────────────
EMS_HOST=${MAC_B_IP}
EMS_PORT=${FIX_PORT}
